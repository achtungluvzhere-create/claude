{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "tradingview": {
      "command": "tradingview-mcp",
      "args": []
    },
    "financekit-mcp": {
      "command": "financekit",
      "args": []
    },
    "cerebrus-pulse-mcp": {
      "command": "cerebrus-pulse-mcp",
      "args": [],
      "env": {
        "CEREBRUS_WALLET_KEY": "",
        "CEREBRUS_WALLET_KEY_SOLANA": ""
      }
    },
    "alpaca": {
      "command": "alpaca-mcp-server",
      "args": [],
      "env": {
        "ALPACA_API_KEY": "",
        "ALPACA_SECRET_KEY": "",
        "ALPACA_BASE_URL": "https://paper-api.alpaca.markets"
      }
    },
    "pinescript-mcp": {
      "command": "pinescript-mcp-server",
      "args": []
    }
  }
}
